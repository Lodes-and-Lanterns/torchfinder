{
  "tasks": {
    "test": "deno test tests/",
    "build": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run build.ts",
    "dev": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run dev.ts"
  },
  "imports": {
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "lz-string": "npm:lz-string@^1.5.0",
    "esbuild": "npm:esbuild@^0.25.0"
  },
  "compilerOptions": {
    "lib": ["ES2024", "DOM", "DOM.Iterable", "deno.ns"]
  },
  "fmt": {
    "exclude": ["**/*.html", "common-web"]
  }
}
